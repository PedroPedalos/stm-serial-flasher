{
  "compilerOptions": {
    "target": "ES2021",
    "module": "Node16",
    "moduleResolution": "node16",
    "rootDir": "src",
    "outDir": "build",
    "lib": ["ES2021", "DOM"],
    "types": ["node"],
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/nodeapp/**/*.ts"],
  "exclude": ["node_modules", "build"]
}
