{
  "name": "stm-serial-flasher",
  "version": "2.0.0",
  "description": "Programmer for STM microcontrollers with the embedded bootloader using Cromium's serial port API",
  "main": "index.js",
  "scripts": {
    "nodeapp:list-ports": "node src/nodeapp/cli.js --list-ports",
    "nodeapp:list-dfu": "node src/nodeapp/cli.js --list-dfu",
    "nodeapp:run": "node src/nodeapp/cli.js",
    "nodeapp:run-dfu": "node src/nodeapp/cli.js --transport dfu --file ./BootloaderChg_G0_V_1_0_7_210426.hex",
    "nodeapp:run-romboot-dfu": "node src/nodeapp/cli.js --transport dfu-romboot --file ./BootloaderChg_G0_V_1_0_7_210426.hex",
    "nodeapp:run-romboot-dfu-fixed": "node src/nodeapp/cli.js --transport dfu-romboot --file ./BootloaderChg_G0_V_1_0_7_210426.hex --romboot-port /dev/tty.usbmodem205C337C46421 --go",
    "nodeapp:run-romboot-dfu-fixed-2": "node src/nodeapp/cli.js --transport dfu-romboot --file ./BootloaderChg_G0-1.0.3.hex --romboot-port /dev/tty.usbmodem205C337C46421 --go",
    "nodeapp:run-port": "node src/nodeapp/cli.js --file ./BootloaderChg_G0_V_1_0_7_210426.hex --port /dev/tty.usbmodem205C337C46421",
    "nodeapp:debug": "node --inspect-brk src/nodeapp/cli.js --file ./BootloaderChg_G0_V_1_0_7_210426.hex --port /dev/tty.usbmodem205C337C46421"
  },
  "repository": {
    "type": "git",
    "url": "git+https://Gamadril@github.com/Gamadril/stm-serial-flasher.git"
  },
  "author": "Gamadril",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Gamadril/stm-serial-flasher/issues"
  },
  "homepage": "https://github.com/Gamadril/stm-serial-flasher#readme",
  "devDependencies": {
  },
  "dependencies": {
    "serialport": "^13.0.0"
  }
}
